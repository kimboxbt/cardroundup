{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/check-cards",
      "schedule": "0 8 * * 1"
    }
  ],
  "functions": {
    "api/check-cards.js": {
      "maxDuration": 90
    },
    "api/cards.js": {
      "maxDuration": 10
    },
    "api/subscribe.js": {
      "maxDuration": 10
    },
    "api/send-digest.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
